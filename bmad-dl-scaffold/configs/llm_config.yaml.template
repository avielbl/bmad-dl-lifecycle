# bmad-dl LLM Configuration — for programmatic script calls only.
# Generated by bmad-dl-init.
#
# ── What this file controls ───────────────────────────────────────────────────
#
#   The model that EXECUTES the SKILL.md agent prompts is configured inside
#   your IDE (Cline model selector, Antigravity settings, Claude Code model
#   picker). This file does NOT affect that.
#
#   This file configures the LLM used by utility scripts that call an LLM
#   programmatically via scripts/llm_client.py — for example, auto-summarization,
#   log interpretation, or any future script that needs an LLM API call.
#
# ── Provider options ──────────────────────────────────────────────────────────
#
#   anthropic          → Claude models via Anthropic API
#   openai-compatible  → Any OpenAI-compatible endpoint:
#                        OpenAI, Ollama, vLLM, Together.ai, Groq, Mistral, Azure, LiteLLM
#
# ── Common configurations ─────────────────────────────────────────────────────

# --- Anthropic / Claude (default) ---
provider: anthropic
model: claude-sonnet-4-6       # or: claude-opus-4-6, claude-haiku-4-5-20251001
base_url: ~                    # leave null for Anthropic
api_key_env: ANTHROPIC_API_KEY # name of the env var holding your API key
max_tokens: 8192
temperature: 0.0               # 0.0 = deterministic; recommended for structured doc output

# --- OpenAI ---
# provider: openai-compatible
# model: gpt-4o                  # or: gpt-4o-mini, o1, o3-mini
# base_url: ~                    # null → uses https://api.openai.com/v1 by default
# api_key_env: OPENAI_API_KEY
# max_tokens: 8192
# temperature: 0.0

# --- Ollama (local) ---
# provider: openai-compatible
# model: llama3.1:70b            # or any model pulled via: ollama pull <model>
# base_url: http://localhost:11434/v1
# api_key_env: OLLAMA_API_KEY    # set to any non-empty string; Ollama ignores it
# max_tokens: 8192
# temperature: 0.0

# --- vLLM (local / self-hosted) ---
# provider: openai-compatible
# model: meta-llama/Llama-3.1-70B-Instruct
# base_url: http://localhost:8000/v1
# api_key_env: VLLM_API_KEY
# max_tokens: 8192
# temperature: 0.0

# --- Together.ai ---
# provider: openai-compatible
# model: meta-llama/Llama-3.1-70B-Instruct-Turbo
# base_url: https://api.together.xyz/v1
# api_key_env: TOGETHER_API_KEY
# max_tokens: 8192
# temperature: 0.0

# --- Groq ---
# provider: openai-compatible
# model: llama-3.1-70b-versatile
# base_url: https://api.groq.com/openai/v1
# api_key_env: GROQ_API_KEY
# max_tokens: 8192
# temperature: 0.0

# --- Mistral ---
# provider: openai-compatible
# model: mistral-large-latest
# base_url: https://api.mistral.ai/v1
# api_key_env: MISTRAL_API_KEY
# max_tokens: 8192
# temperature: 0.0

# --- Azure OpenAI ---
# provider: openai-compatible
# model: gpt-4o                  # deployment name in Azure
# base_url: https://<your-resource>.openai.azure.com/openai/deployments/<deployment>/
# api_key_env: AZURE_OPENAI_API_KEY
# max_tokens: 8192
# temperature: 0.0

# ── Notes ─────────────────────────────────────────────────────────────────────
#
# Environment variable override (no config file needed):
#   BMAD_LLM_PROVIDER   — overrides provider
#   BMAD_LLM_MODEL      — overrides model
#   BMAD_LLM_BASE_URL   — overrides base_url
#   BMAD_LLM_API_KEY_ENV — overrides api_key_env
#   BMAD_LLM_MAX_TOKENS — overrides max_tokens
#   BMAD_LLM_TEMPERATURE — overrides temperature
#
# The api_key itself is NEVER stored here. It lives in the env var named
# by api_key_env. Add to .env (and .gitignore it):
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
